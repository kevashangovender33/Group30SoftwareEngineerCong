// Prisma schema for the Payment Dispute Triage System
// REQ-001: All data is localized mock data (SQLite)
// REQ-002: Payment types limited to CARD, EFT, INTERNAL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  accountNumber String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]
  disputes      Dispute[]
}

model Transaction {
  id              String   @id @default(uuid())
  customerId      String
  amount          Float
  paymentType     String   // CARD | EFT | INTERNAL
  status          String   // COMPLETED | PENDING | FAILED | ALREADY_REFUNDED
  description     String
  transactionDate DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id])
  disputes Dispute[]
}

model Dispute {
  id                String   @id @default(uuid())
  referenceNumber   String   @unique
  customerId        String
  transactionId     String
  paymentType       String   // CARD | EFT | INTERNAL
  issueCategory     String   // DUPLICATE_DEBIT | FAILED_TRANSFER | MISSING_PAYMENT | UNAUTHORISED | INCORRECT_AMOUNT | CARD_DISPUTE
  status            String   @default("OPEN") // OPEN | TRIAGED | CLOSED
  priority          String   @default("LOW") // HIGH | MEDIUM | LOW
  ageIndicator      String   @default("NEW") // NEW | AGING | OVERDUE
  recommendedAction String?
  triggeredRules    String?  // JSON array of rule descriptions
  createdAt         DateTime @default(now())
  resolvedAt        DateTime?
  updatedAt         DateTime @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])
}
