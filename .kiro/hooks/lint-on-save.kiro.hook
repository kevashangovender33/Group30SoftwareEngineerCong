{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs ESLint on TypeScript and TSX files whenever they are saved, reporting any lint errors.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run lint"
  }
}