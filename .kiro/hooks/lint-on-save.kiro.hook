{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs ESLint on TypeScript and TSX files whenever they are saved, catching lint errors immediately.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx eslint --no-warn-ignored \"$KIRO_FILE_PATH\""
  }
}